# Frontend
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:3301

# Local v2 Postgres (isolated from Chatwoot and from the old portal)
PORTAL_V2_POSTGRES_PORT=55433
PORTAL_V2_POSTGRES_DB=chatwoot_client_portal_v2
PORTAL_V2_POSTGRES_USER=portal_v2
PORTAL_V2_POSTGRES_PASSWORD=portal_v2_local_dev_password

# Backend
NODE_ENV=development
PORT=3301
PORTAL_TRUST_PROXY=false
APP_ORIGIN=http://127.0.0.1:5173
SESSION_COOKIE_NAME=portal_session
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_DAYS=14
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=60000
DATABASE_URL=postgresql://portal_v2:portal_v2_local_dev_password@127.0.0.1:55433/chatwoot_client_portal_v2
CHATWOOT_BASE_URL=http://127.0.0.1:3000
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_ACCESS_TOKEN=replace-with-chatwoot-api-token
CHATWOOT_PORTAL_INBOX_ID=1
CHATWOOT_REQUEST_TIMEOUT_MS=15000
CHATWOOT_WEBHOOK_CALLBACK_URL=http://127.0.0.1:3301/api/integrations/chatwoot/webhooks/account
CHATWOOT_WEBHOOK_SECRET=replace-with-chatwoot-webhook-secret

# MT-1 default tenant bootstrap.
# Generate with: openssl rand -base64 32
PORTAL_TENANT_SECRET_KEY=replace-with-base64-32-byte-secret
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_DISPLAY_NAME="Local Default Tenant"
DEFAULT_TENANT_PRIMARY_DOMAIN=127.0.0.1
DEFAULT_TENANT_PUBLIC_BASE_URL=http://127.0.0.1:5173
DEFAULT_TENANT_CHATWOOT_BASE_URL=http://127.0.0.1:3000
DEFAULT_TENANT_CHATWOOT_ACCOUNT_ID=1
DEFAULT_TENANT_CHATWOOT_PORTAL_INBOX_ID=1
DEFAULT_TENANT_CHATWOOT_API_ACCESS_TOKEN=replace-with-chatwoot-api-token
DEFAULT_TENANT_CHATWOOT_WEBHOOK_SECRET=replace-with-chatwoot-webhook-secret

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
