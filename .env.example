# Frontend
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:3301

# Local v2 Postgres (isolated from Chatwoot and from the old portal)
PORTAL_V2_POSTGRES_PORT=55433
PORTAL_V2_POSTGRES_DB=chatwoot_client_portal_v2
PORTAL_V2_POSTGRES_USER=portal_v2
PORTAL_V2_POSTGRES_PASSWORD=portal_v2_local_dev_password

# Backend
NODE_ENV=development
PORT=3301
PORTAL_TRUST_PROXY=false
APP_ORIGIN=http://127.0.0.1:5173
ADMIN_SESSION_COOKIE_NAME=portal_admin_session
SESSION_COOKIE_NAME=portal_session
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_DAYS=14
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=60000
DATABASE_URL=postgresql://portal_v2:portal_v2_local_dev_password@127.0.0.1:55433/chatwoot_client_portal_v2
CHATWOOT_REQUEST_TIMEOUT_MS=15000
# Optional comma-separated public object-storage/CDN origins used by Chatwoot attachment redirects.
CHAT_ATTACHMENT_PROXY_ALLOWED_ORIGINS=

# MT-1 default tenant bootstrap.
# Generate with: openssl rand -base64 32
PORTAL_TENANT_SECRET_KEY=replace-with-base64-32-byte-secret
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_DISPLAY_NAME="Local Default Tenant"
DEFAULT_TENANT_PRIMARY_DOMAIN=127.0.0.1
DEFAULT_TENANT_PUBLIC_BASE_URL=http://127.0.0.1:5173
DEFAULT_TENANT_CHATWOOT_BASE_URL=http://127.0.0.1:3000
DEFAULT_TENANT_CHATWOOT_ACCOUNT_ID=1
DEFAULT_TENANT_CHATWOOT_PORTAL_INBOX_ID=1
DEFAULT_TENANT_CHATWOOT_API_ACCESS_TOKEN=replace-with-chatwoot-api-token
# Optional: separate user access token for tenant admin verification.
# Do not use this as the customer chat runtime token unless intentionally identical.
DEFAULT_TENANT_CHATWOOT_ADMIN_VERIFICATION_TOKEN=
DEFAULT_TENANT_CHATWOOT_WEBHOOK_SECRET=replace-with-chatwoot-webhook-secret

# Playwright e2e test harness only. These values let tests create fixture
# contacts in the external Chatwoot instance without becoming portal runtime
# authority.
E2E_CHATWOOT_BASE_URL=http://127.0.0.1:3000
E2E_CHATWOOT_ACCOUNT_ID=1
E2E_CHATWOOT_PORTAL_INBOX_ID=1
E2E_CHATWOOT_API_ACCESS_TOKEN=replace-with-chatwoot-api-token

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Web Push VAPID keys. Leave empty to keep browser push unavailable locally.
# Generate keys with a trusted Web Push/VAPID tool and keep the private key secret.
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:noreply@example.com
PUSH_VAPID_KEY_ID=
# Comma-separated exact push service origins. Defaults cover Chrome/Firefox/Safari.
PUSH_SUBSCRIPTION_ALLOWED_ORIGINS=https://fcm.googleapis.com,https://updates.push.services.mozilla.com,https://web.push.apple.com
