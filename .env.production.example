# Copy this file to `.env.production` on the production VM.
# Never commit `.env.production`.

# Public portal origin. DNS must point this host to the VM public IP.
PORTAL_DOMAIN=portal.example.com
APP_ORIGIN=https://portal.example.com

# Web container listener.
# Standalone mode: Caddy listens publicly and manages HTTPS.
PORTAL_DEPLOYMENT_MODE=standalone
PORTAL_CADDY_SITE_ADDRESS=portal.example.com
PORTAL_HTTP_BIND=0.0.0.0
PORTAL_HTTP_PORT=80
PORTAL_HTTPS_BIND=0.0.0.0
PORTAL_HTTPS_PORT=443

# Existing reverse proxy mode, when Chatwoot/Nginx already owns 80/443 on the VM:
# PORTAL_CADDY_SITE_ADDRESS=:80
# PORTAL_HTTP_BIND=127.0.0.1
# PORTAL_HTTP_PORT=8088
# PORTAL_HTTPS_BIND=127.0.0.1
# PORTAL_HTTPS_PORT=8448

# Backend runtime.
NODE_ENV=production
PORT=3301
SESSION_COOKIE_NAME=portal_session
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SESSION_TTL_DAYS=14

# Isolated portal Postgres. Do not use the Chatwoot database.
PORTAL_V2_POSTGRES_DB=chatwoot_client_portal_v2
PORTAL_V2_POSTGRES_USER=portal_v2
PORTAL_V2_POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://portal_v2:replace-with-a-strong-db-password@portal-db:5432/chatwoot_client_portal_v2

# Existing production Chatwoot.
CHATWOOT_BASE_URL=https://chatwoot.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_ACCESS_TOKEN=replace-with-dedicated-chatwoot-api-token
CHATWOOT_PORTAL_INBOX_ID=1
CHATWOOT_WEBHOOK_CALLBACK_URL=https://portal.example.com/api/integrations/chatwoot/webhooks/account
# Installer flow replaces the bootstrap value with Chatwoot's actual webhook secret after provisioning.
CHATWOOT_WEBHOOK_SECRET=replace-with-chatwoot-webhook-secret

# SMTP provider for registration/password-reset emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@example.com
