# Copy this file to `.env.production` on the production VM.
# Never commit `.env.production`.

# Public portal origin. DNS must point this host to the VM public IP.
PORTAL_DOMAIN=lk.example.com
APP_ORIGIN=https://lk.example.com

# Web container listener.
# Standalone mode: Caddy listens publicly and manages HTTPS.
PORTAL_DEPLOYMENT_MODE=standalone
PORTAL_CADDY_SITE_ADDRESS=lk.example.com
PORTAL_HTTP_BIND=0.0.0.0
PORTAL_HTTP_PORT=80
PORTAL_HTTPS_BIND=0.0.0.0
PORTAL_HTTPS_PORT=443

# Existing reverse proxy mode, when Chatwoot/Nginx already owns 80/443 on the VM:
# PORTAL_CADDY_SITE_ADDRESS=:80
# PORTAL_HTTP_BIND=127.0.0.1
# PORTAL_HTTP_PORT=8088
# PORTAL_HTTPS_BIND=127.0.0.1
# PORTAL_HTTPS_PORT=8448

# Backend runtime.
NODE_ENV=production
PORT=3301
# Backend is only reachable through the portal reverse proxy in production compose.
PORTAL_TRUST_PROXY=true
ADMIN_SESSION_COOKIE_NAME=portal_admin_session
SESSION_COOKIE_NAME=portal_session
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SESSION_TTL_DAYS=14
CHATWOOT_REQUEST_TIMEOUT_MS=15000

# MT-10A operator tenant provisioning. Leave empty on ordinary runtime nodes
# unless this deployment also runs tenant provisioning scripts.
CHATWOOT_PLATFORM_API_ACCESS_TOKEN=
PORTAL_PROVIDER_TENANT_DOMAIN_SUFFIX=
PORTAL_PROVISIONING_SERVICE_EMAIL_DOMAIN=

# Portal-owned branding asset object storage.
# Default production install runs internal MinIO on the Docker network.
# These values are portal infrastructure: normal B2B clients do not provision
# buckets or storage credentials. External S3-compatible providers are not
# supported in this slice and need a separate operator-mode plan.
PORTAL_OBJECT_STORAGE_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
PORTAL_OBJECT_STORAGE_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z
PORTAL_OBJECT_STORAGE_ROOT_USER=portal_v2_minio_root
PORTAL_OBJECT_STORAGE_ROOT_PASSWORD=generated-by-installer

BRANDING_ASSET_STORAGE_ENDPOINT=http://portal-object-storage:9000
BRANDING_ASSET_STORAGE_REGION=us-east-1
BRANDING_ASSET_STORAGE_BUCKET=portal-branding-assets
BRANDING_ASSET_STORAGE_ACCESS_KEY_ID=portal_v2_branding_assets
BRANDING_ASSET_STORAGE_SECRET_ACCESS_KEY=generated-by-installer
BRANDING_ASSET_STORAGE_FORCE_PATH_STYLE=true

# Isolated portal Postgres. Do not use the Chatwoot database.
PORTAL_V2_POSTGRES_DB=chatwoot_client_portal_v2
PORTAL_V2_POSTGRES_USER=portal_v2
PORTAL_V2_POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql://portal_v2:replace-with-a-strong-db-password@portal-db:5432/chatwoot_client_portal_v2

# Default tenant bootstrap.
# Generate with: openssl rand -base64 32
PORTAL_TENANT_SECRET_KEY=replace-with-base64-32-byte-secret
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_DISPLAY_NAME="Default Tenant"
DEFAULT_TENANT_PRIMARY_DOMAIN=lk.example.com
DEFAULT_TENANT_PUBLIC_BASE_URL=https://lk.example.com
DEFAULT_TENANT_CHATWOOT_BASE_URL=https://chatwoot.example.com
DEFAULT_TENANT_CHATWOOT_ACCOUNT_ID=1
DEFAULT_TENANT_CHATWOOT_PORTAL_INBOX_ID=1
DEFAULT_TENANT_CHATWOOT_API_ACCESS_TOKEN=replace-with-dedicated-chatwoot-api-token
# Required for /admin/login: separate Chatwoot admin user access token.
# Create/copy it from a confirmed Chatwoot administrator Profile Settings.
DEFAULT_TENANT_CHATWOOT_ADMIN_VERIFICATION_TOKEN=replace-with-dedicated-chatwoot-admin-verification-token
# Temporary bootstrap value. The installer replaces the stored tenant secret
# with Chatwoot v4.13+ API Channel webhook secret during tenant webhook setup.
DEFAULT_TENANT_CHATWOOT_WEBHOOK_SECRET=replace-with-temporary-bootstrap-webhook-secret

# SMTP provider for registration/password-reset emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@example.com

# Web Push VAPID keys for browser/PWA push notifications.
# Generate one key pair per deployment/environment and keep the private key secret.
PUSH_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:noreply@example.com
PUSH_VAPID_KEY_ID=production-2026-05
PUSH_SUBSCRIPTION_ALLOWED_ORIGINS=https://fcm.googleapis.com,https://updates.push.services.mozilla.com,https://web.push.apple.com
