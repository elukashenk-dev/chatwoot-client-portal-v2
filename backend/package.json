{
  "name": "@chatwoot-client-portal-v2/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "tenant:bootstrap-default": "tsx src/scripts/bootstrap-default-tenant.ts",
    "tenant:create": "tsx src/scripts/create-tenant.ts",
    "tenant:deprovision": "tsx src/scripts/deprovision-tenant.ts",
    "tenant:chatwoot:reconcile": "tsx src/scripts/reconcile-tenants.ts",
    "tenant:chatwoot:ensure-portal-inbox": "tsx src/scripts/verify-tenant-chatwoot-connection.ts",
    "tenant:chatwoot:webhook:configure": "tsx src/scripts/configure-tenant-chatwoot-webhook.ts",
    "tenant:chatwoot:verify": "tsx src/scripts/verify-tenant-chatwoot-connection.ts",
    "maintenance:cleanup": "tsx src/scripts/cleanup-maintenance-data.ts",
    "user:create": "tsx src/scripts/create-user.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/runMigrations.ts",
    "lint": "eslint .",
    "test": "vitest run --no-file-parallelism --reporter verbose"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
