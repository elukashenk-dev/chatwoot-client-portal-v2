    "db:migrate": "tsx src/db/runMigrations.ts",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
