{
  "name": "@chatwoot-client-portal-v2/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "user:create": "tsx src/scripts/create-user.ts",
